rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'data', 'userId', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 256 &&
             data.data is string && data.data.size() <= 1048576 && // 1MB limit check
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    function isValidTemplate(data) {
      return data.keys().hasAll(['name', 'category', 'previewUrl', 'canvasData', 'createdAt']) &&
             data.name is string && data.name.size() <= 256 &&
             data.category is string &&
             data.previewUrl is string &&
             data.canvasData is string &&
             data.createdAt is timestamp;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().email == existing().email &&
                      incoming().createdAt == existing().createdAt;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && 
                      isValidProject(incoming()) && 
                      existing().userId == request.auth.uid &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      (
                        // Action: Update Data/Name/Preview
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'preview', 'updatedAt'])
                      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Admin SDK or Console
    }
  }
}
