rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ID poisoning guard
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /test/connection {
      allow read: if true;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             (request.method == 'create' ? data.createdAt == request.time : true) &&
             data.updatedAt == request.time;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() <= 256 &&
             data.data is string && data.data.size() <= 2097152 && // Allow up to 2MB for big canvas states
             data.userId is string && data.userId == request.auth.uid &&
             (request.method == 'create' ? data.createdAt == request.time : true) &&
             data.updatedAt == request.time;
    }

    function isValidContent(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             (request.method == 'create' ? data.createdAt == request.time : true) &&
             (data.updatedAt == request.time || !('updatedAt' in data));
    }

    function isValidAnalytics(data) {
      return (data.sessionId is string && data.sessionId.size() <= 128) || 
             (data.userId is string && data.userId == request.auth.uid);
    }

    // --- Collection Routes ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['email', 'updatedAt']);
    }

    // Design Projects
    match /projects/{projectId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidProject(incoming()) && isValidId(projectId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                    isValidProject(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'preview', 'updatedAt']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Global Read-only Templates
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false; 
    }

    // Analytics (Used by admin and tracking scripts)
    match /analytics_sessions/{sessionId} {
      allow create: if isValidId(sessionId);
      allow update: if isValidId(sessionId) || isSignedIn();
      allow get: if isSignedIn();
    }
    match /analytics_uploads/{id} {
      allow create: if isValidAnalytics(incoming()) && isValidId(id);
      allow read: if isSignedIn();
    }
    match /analytics_exports/{id} {
      allow create: if isValidAnalytics(incoming()) && isValidId(id);
      allow read: if isSignedIn();
    }
    match /analytics_actions/{id} {
      allow create: if isValidAnalytics(incoming()) && isValidId(id);
      allow read: if isSignedIn();
    }
    
    // Explicit 'session' and 'analytics' for edge cases
    match /session/{id} {
        allow create, update: if isValidId(id) || isSignedIn();
        allow read: if isSignedIn();
    }
    match /analytics/{id} {
        allow create, update: if isValidAnalytics(incoming()) || isSignedIn();
        allow read: if isSignedIn();
    }

    // User Content Collections
    match /history/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidContent(incoming()) && isValidId(docId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidContent(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
    match /drafts/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidContent(incoming()) && isValidId(docId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidContent(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
    match /chatHistory/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidContent(incoming()) && isValidId(docId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidContent(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
