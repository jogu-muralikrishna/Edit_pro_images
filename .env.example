# Gemini API Key (Required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Unsplash Access Key (Required for stock photos)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API Key (Required for stock photos)
PEXELS_API_KEY=your_pexels_api_key_here

# Secret analytics key
ANALYTICS_JWT_SECRET=your_secret_key_here

# Firebase Configuration (Can be replaced with your own firebase-applet-config.json)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Backend Firebase Service Account (JSON string)
FIREBASE_SERVICE_ACCOUNT=
# Specific Firestore Database ID (if not "default")
FIREBASE_DATABASE_ID=
