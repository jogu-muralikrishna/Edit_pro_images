{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information mirrored from Firebase Auth.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Project": {
      "title": "Design Project",
      "description": "A design project containing canvas state.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "data": { "type": "string", "description": "JSON string of Fabric.js canvas state" },
        "preview": { "type": "string", "description": "Base64 or URL" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "data", "userId", "createdAt", "updatedAt"]
    },
    "Template": {
      "title": "Design Template",
      "description": "Pre-built templates for users to start from.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "previewUrl": { "type": "string" },
        "canvasData": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "previewUrl", "canvasData", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles."
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "User designs."
    },
    "templates/{templateId}": {
      "schema": "Template",
      "description": "Global templates accessible to all."
    },
    "test/connection": {
      "schema": "object",
      "description": "Dummy document for connectivity testing."
    },
    "analytics_sessions/{sessionId}": {
      "schema": {
        "title": "User Session",
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ip": { "type": "string" },
          "geo": { "type": "object" },
          "fingerprint": { "type": "string" },
          "device": { "type": "object" },
          "firstSeen": { "type": "string", "format": "date-time" },
          "lastSeen": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "ip", "fingerprint", "firstSeen", "lastSeen"]
      },
      "description": "Tracking user sessions."
    },
    "analytics_uploads/{uploadId}": {
      "schema": {
        "title": "Uploaded Image",
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "url": { "type": "string" },
          "thumbnail": { "type": "string" },
          "exif": { "type": "object" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["sessionId", "url", "timestamp"]
      },
      "description": "Tracking image uploads."
    },
    "analytics_exports/{exportId}": {
      "schema": {
        "title": "Edited Image",
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "image": { "type": "string", "description": "DataURL or URL" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["sessionId", "image", "timestamp"]
      },
      "description": "Tracking final exports."
    },
    "analytics_actions/{actionId}": {
      "schema": {
        "title": "User Action",
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "type": { "type": "string" },
          "details": { "type": "object" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["sessionId", "type", "timestamp"]
      },
      "description": "Tracking user activity."
    },
    "session/{sessionId}": {
      "schema": "object",
      "description": "Legacy/Alternate session tracking."
    },
    "analytics/{id}": {
      "schema": "object",
      "description": "Legacy/Alternate analytics data."
    },
    "history/{historyId}": {
      "schema": "object",
      "description": "User design history."
    },
    "drafts/{draftId}": {
      "schema": "object",
      "description": "Unfinished designs."
    },
    "chatHistory/{chatId}": {
      "schema": "object",
      "description": "AI Assistant chat history."
    }
  }
}
